# ReconForge Environment Variables
# Copy to .dev.vars for local Worker runtime secrets

# Deploy credentials (not committed): copy .cloudflare.env.example → .cloudflare.env
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# Simulation mode (default: true — safe for demos)
SIMULATION_MODE=true

# ── Future Live Integration API Keys ──────────────────────────────
# Uncomment and set when connecting real recon services:

# Certificate Transparency (crt.sh is free, no key needed)
# CRT_SH_API=

# Shodan API for host/port intelligence
# SHODAN_API_KEY=your_shodan_api_key

# NVD API for CVE lookups
# NVD_API_KEY=your_nvd_api_key

# Hunter.io for email OSINT
# HUNTER_API_KEY=your_hunter_api_key

# SecurityTrails for DNS history
# SECURITYTRAILS_API_KEY=your_securitytrails_key
